generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 엑셀 업로드 이력
model Upload {
  id        String   @id @default(cuid())
  fileName  String
  month     String   // "2026-03" 형태
  sheetName String?
  rowCount  Int      @default(0)
  createdAt DateTime @default(now())
  sales     Sale[]

  @@map("uploads")
}

// 부서
model Department {
  id    String  @id @default(cuid())
  name  String  @unique
  staff Staff[]

  @@map("departments")
}

// 담당자
model Staff {
  id           String     @id @default(cuid())
  code         String?    @unique // 담당자코드 (503006 등)
  name         String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  customers    Customer[]
  sales        Sale[]

  @@map("staff")
}

// 거래처
model Customer {
  id       String  @id @default(cuid())
  code     String? @unique // 거래처코드
  name     String
  grade    String? // 등급
  market   String? // 유통시장
  region   String? // 지역
  staffId  String?
  staff    Staff?  @relation(fields: [staffId], references: [id])
  sales    Sale[]

  @@map("customers")
}

// 상품(품목)
model Product {
  id        String   @id @default(cuid())
  code      String?  @unique // 품목코드
  name      String
  oldName   String?  // 구품목명
  category  String?  // 분류 (WD-40, BW-100 등)
  volume    String?  // 용량
  unit      String?  // 포장단위 (EA, BOX 등)
  price     Float?   // 기본 단가
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]

  @@map("products")
}

// 매출(출고) 데이터 - 엑셀 업로드의 핵심 테이블
model Sale {
  id            String   @id @default(cuid())
  uploadId      String?
  upload        Upload?  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  staffId       String?
  staff         Staff?   @relation(fields: [staffId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  saleType      String?  // 매출구분 (매출, 반품 등)
  saleDate      DateTime? // 거래일자
  month         String?  // "2026-03"
  weekNumber    Int?     // 주차 (1~5)
  quantity      Int      @default(0) // 수량
  unitPrice     Float    @default(0) // 단가
  supplyAmount  Float    @default(0) // 공급가액
  taxAmount     Float    @default(0) // 부가세액
  totalAmount   Float    @default(0) // 합계금액
  planQuantity  Int?     // 계획수량
  prevYearQty   Int?     // 전년수량
  createdAt     DateTime @default(now())

  @@map("sales")
}
